# ===========================================
# Discord Bot Configuration
# Copy this file to .env and fill in your keys
# ===========================================

# Required – your Discord bot token and Groq API key
DISCORD_TOKEN=your_discord_bot_token
GROQ_API_KEY=your_groq_api_key

# Bot Settings
BOT_PREFIX=!
BOT_LANGUAGE=en

# LLM Provider: groq (default) or vertex
LLM_PROVIDER=groq
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_TRANSCRIBE_MODEL=whisper-large-v3-turbo

# Google Vertex AI (optional, set LLM_PROVIDER=vertex)
# VERTEX_API_KEY=your_vertex_api_key
# VERTEX_BASE_URL=https://aiplatform.googleapis.com
# VERTEX_PROJECT_ID=your_vertex_project_id
# VERTEX_LOCATION=global
# VERTEX_MODEL=gemini-2.5-flash

# Auto-Join – automatically join voice channels
AUTO_JOIN_VOICE_CHANNELS=true
AUTO_JOIN_MANUAL_LEAVE_COOLDOWN_MS=60000
AUTO_JOIN_RETRY_COOLDOWN_MS=15000

# Conversation Behavior – cooldowns and filtering
GLOBAL_REPLY_COOLDOWN_MS=4500
USER_REPLY_COOLDOWN_MS=7000
BOT_ECHO_GUARD_MS=2200
DUPLICATE_TRANSCRIPT_WINDOW_MS=20000
MIN_TRANSCRIPT_CHARS=3
MIN_TRANSCRIPT_WORDS=2
IGNORE_COURTESY_ONLY=true
CHAT_MAX_TOKENS=220
MAX_TTS_CHARS=420
MEMORY_MAX_MESSAGES=24
MEMORY_MAX_CHARS=7000
BOT_WAKE_WORDS=bot,discord bot
TTS_ERROR_NOTIFY_COOLDOWN_MS=60000

# TTS Provider: elevenlabs (recommended) or google (free)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_VOICE_PRESET=balanced
# TTS_PROVIDER=elevenlabs
